# Environment configuration for local development
# Copy this file to .env and modify the values as needed

# Database Configuration
DATABASE_URL=postgresql+asyncpg://your_username:your_password@localhost:5432/your_database_name

# Alternative individual settings (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name

# Server Configuration
HOST=0.0.0.0
PORT=8000

# NLP Model Configuration (safe defaults for low internet)
# Keep disabled to use rule-based SQL generation (no model download)
ENABLE_HF_MODEL=false
# If ENABLE_HF_MODEL=true, keep this true to use only already-cached local model files
HF_LOCAL_FILES_ONLY=true
# Optional local cache path for pre-downloaded models
# HF_MODEL_CACHE_DIR=./hf_cache

# Example configurations for different databases:

# Local PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/myapp

# Local MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/myapp

# SQLite (for testing):
# DATABASE_URL=sqlite+aiosqlite:///./local_test.db